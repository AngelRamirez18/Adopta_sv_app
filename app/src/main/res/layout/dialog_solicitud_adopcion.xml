<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_secondary">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_paw"
                    app:tint="@color/md_on_secondary_container"
                    android:contentDescription="Adopción" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solicitud de adopción"
                    android:textColor="@color/md_on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completa todos los campos"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- tipo_vivienda -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="¿En qué tipo de vivienda vives?"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTipoVivienda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Ej: casa, apartamento…"
            android:textColor="@color/md_on_surface"
            android:textColorHint="@color/md_on_surface_variant"
            android:inputType="text|textCapSentences"
            android:maxLines="1"
            android:padding="14dp" />

        <!-- tiene_patio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="¿Tu vivienda tiene patio?"
                android:textColor="@color/md_on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swTienePatio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- otros_animales -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="¿Tienes otras mascotas?"
                android:textColor="@color/md_on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swOtrosAnimales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- experiencia -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="¿Tienes experiencia con mascotas?"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etExperiencia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Cuéntanos tu experiencia…"
            android:textColor="@color/md_on_surface"
            android:textColorHint="@color/md_on_surface_variant"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2"
            android:gravity="top|start"
            android:padding="14dp" />

        <!-- horas_en_casa -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="¿Cuántas horas al día estás en casa?"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etHorasEnCasa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Número entre 0 y 24"
            android:textColor="@color/md_on_surface"
            android:textColorHint="@color/md_on_surface_variant"
            android:inputType="number"
            android:maxLines="1"
            android:padding="14dp" />

        <!-- compromiso -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="¿Por qué quieres adoptar esta mascota?"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCompromiso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Cuéntanos tu motivación y compromiso…"
            android:textColor="@color/md_on_surface"
            android:textColorHint="@color/md_on_surface_variant"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:gravity="top|start"
            android:padding="14dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
