<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/adopta_card"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivIcono"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_home_marker"
            android:contentDescription="Tipo" />

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Refugio"
            android:textColor="@color/adopta_dark"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDistancia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@color/adopta_badge_crema"
            android:text="0.4 km"
            android:textColor="@color/adopta_brown"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="—"
        android:textColor="@color/adopta_dark"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp" />

    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:text="Nuevo"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>
