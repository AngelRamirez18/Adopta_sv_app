<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_container_lowest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Adoptante -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivAvatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Adoptante" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAdoptante"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Elena Ramírez"
                    android:textColor="@color/md_on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvSubAdoptante"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Solicitante de adopción"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvMatch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_tertiary"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="95% Match"
                android:textColor="@color/md_on_tertiary_fixed_variant"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Mascota -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_rounded"
            android:padding="10dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivMascota"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/mascota"
                android:contentDescription="Mascota" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMascota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Oliver"
                    android:textColor="@color/md_on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvQuote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Busco un compañero activo"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- Ver detalles -->
        <TextView
            android:id="@+id/tvVerDetalles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:text="Ver formulario del adoptante →"
            android:textColor="@color/md_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="4dp"
            android:background="?attr/selectableItemBackground" />

        <!-- Acciones -->
        <LinearLayout
            android:id="@+id/llAcciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAprobar"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Aprobar"
                android:textColor="@color/md_on_secondary_container"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:icon="@drawable/ic_check_circle"
                app:iconGravity="textStart"
                app:iconTint="@color/md_on_secondary_container"
                app:cornerRadius="999dp"
                app:backgroundTint="@color/md_secondary_container"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRechazar"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Rechazar"
                android:textColor="@color/md_on_surface_variant"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:icon="@drawable/ic_close_small"
                app:iconGravity="textStart"
                app:iconTint="@color/md_on_surface_variant"
                app:cornerRadius="999dp"
                app:backgroundTint="@color/md_surface_container"
                app:elevation="0dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
