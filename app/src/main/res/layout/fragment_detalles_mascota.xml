<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface">

    <!-- ───── Contenido scrolleable ───── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ───── Hero 4:5 ───── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/ivFoto"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder_mascota"
                    android:contentDescription="Foto de la mascota"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintDimensionRatio="H,4:5" />

                <!-- Miniaturas -->
                <LinearLayout
                    android:id="@+id/llThumbsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:background="@drawable/bg_thumb"
                    android:padding="6dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/ivFoto">

                    <LinearLayout
                        android:id="@+id/llThumbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </LinearLayout>

                <!-- Contador -->
                <TextView
                    android:id="@+id/tvContador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:background="@drawable/bg_counter"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="1/3"
                    android:textColor="#FFE3D1"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/ivFoto" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ───── Hoja de contenido solapada ───── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-28dp"
                android:background="@drawable/bg_sheet_top"
                android:paddingHorizontal="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="32dp">

                <!-- Encabezado: nombre / ubicación / raza + estado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNombre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toby"
                            android:textColor="@color/md_on_surface"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="-0.02" />

                        <LinearLayout
                            android:id="@+id/llUbicacion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_location_on"
                                android:contentDescription="Ubicación" />

                            <TextView
                                android:id="@+id/tvUbicacion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="San Salvador, SV"
                                android:textColor="@color/md_on_surface_variant"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvRaza"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Golden Retriever"
                            android:textColor="@color/md_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEstadoAdopcion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_pill_secondary_fixed"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="Adoptable"
                        android:textColor="@color/md_on_secondary_fixed"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ───── Bento grid ───── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <!-- Edad -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_bento"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EDAD"
                            android:textColor="@color/md_on_surface_variant"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvEdadNum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="2"
                            android:textColor="@color/md_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEdadUnidad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="años"
                            android:textColor="@color/md_on_surface_variant"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Sexo -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_bento_alt"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SEXO"
                            android:textColor="@color/md_on_surface_variant"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <ImageView
                            android:id="@+id/ivSexo"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginTop="4dp"
                            android:src="@drawable/ic_male"
                            android:contentDescription="Sexo" />

                        <TextView
                            android:id="@+id/tvSexo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Macho"
                            android:textColor="@color/md_on_surface_variant"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Tamaño -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_bento"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TAMAÑO"
                            android:textColor="@color/md_on_surface_variant"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvTamano"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="6dp"
                            android:text="Mediano"
                            android:textColor="@color/md_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ───── Sobre mí ───── -->
                <TextView
                    android:id="@+id/tvLblAbout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Sobre mí"
                    android:textColor="@color/md_on_surface"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="—"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="16sp" />

                <!-- ───── Personalidad ───── -->
                <TextView
                    android:id="@+id/tvLblPersonalidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Personalidad"
                    android:textColor="@color/md_on_surface"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgPersonalidad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:chipSpacingVertical="8dp"
                    app:chipSpacingHorizontal="8dp" />

                <!-- ───── Salud y cuidados ───── -->
                <TextView
                    android:id="@+id/tvLblSalud"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Salud y Cuidados"
                    android:textColor="@color/md_on_surface"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/llSalud"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ───── Header flotante ───── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#CCFBF9F5">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_back"
            android:padding="9dp"
            app:tint="@color/md_primary"
            android:contentDescription="Volver" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvFav"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#CCFBF9F5">

        <ImageButton
            android:id="@+id/btnFavorito"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_heart"
            android:padding="9dp"
            app:tint="@color/md_primary"
            android:contentDescription="Favorito" />
    </androidx.cardview.widget.CardView>

    <!-- ───── Footer fijo ───── -->
    <LinearLayout
        android:id="@+id/llBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:visibility="gone"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F2FBF9F5"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdoptar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Adoptar ahora"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@color/md_on_secondary_container"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/md_secondary_container" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChat"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="28dp"
            app:strokeWidth="0dp"
            app:backgroundTint="@color/md_surface_container_high"
            app:icon="@drawable/ic_chat"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/md_primary"
            android:contentDescription="Mensaje" />
    </LinearLayout>

    <!-- ───── Loading ───── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/md_secondary_container" />

    <!-- ───── Error ───── -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="32dp"
        android:gravity="center"
        android:textColor="@color/md_primary"
        android:textSize="14sp"
        android:visibility="gone" />

</FrameLayout>
