<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface">

    <LinearLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="38dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/md_primary"
            android:contentDescription="Volver" />

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Nueva mascota"
            android:textColor="@color/md_on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Foto -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_surface_container">

                <ImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Foto de la mascota" />

                <LinearLayout
                    android:id="@+id/llAddFoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/md_on_surface_variant"
                        android:contentDescription="Añadir foto" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Añadir foto"
                        android:textColor="@color/md_on_surface_variant"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView style="@style/AdminLabel" android:text="Nombre *" />
            <EditText
                android:id="@+id/etNombre"
                style="@style/AdminField"
                android:hint="Ej: Max"
                android:inputType="text|textCapWords" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">

                    <TextView style="@style/AdminLabel" android:text="Especie *" />
                    <Spinner
                        android:id="@+id/spEspecie"
                        style="@style/AdminSpinner" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">

                    <TextView style="@style/AdminLabel" android:text="Sexo *" />
                    <Spinner
                        android:id="@+id/spSexo"
                        style="@style/AdminSpinner" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">

                    <TextView style="@style/AdminLabel" android:text="Edad (meses)" />
                    <EditText
                        android:id="@+id/etEdad"
                        style="@style/AdminField"
                        android:hint="Ej: 18"
                        android:inputType="number" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">

                    <TextView style="@style/AdminLabel" android:text="Tamaño" />
                    <Spinner
                        android:id="@+id/spTamano"
                        style="@style/AdminSpinner" />
                </LinearLayout>
            </LinearLayout>

            <TextView style="@style/AdminLabel" android:text="Raza" />
            <EditText
                android:id="@+id/etRaza"
                style="@style/AdminField"
                android:hint="Ej: Labrador mestizo"
                android:inputType="text|textCapWords" />

            <TextView style="@style/AdminLabel" android:text="Descripción" />
            <EditText
                android:id="@+id/etDescripcion"
                style="@style/AdminField"
                android:hint="Contá cómo es la mascota..."
                android:minLines="3"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences" />

            <TextView style="@style/AdminLabel" android:text="Personalidad (separá por comas)" />
            <EditText
                android:id="@+id/etPersonalidad"
                style="@style/AdminField"
                android:hint="jugueton, cariñoso, activo"
                android:inputType="text" />

            <TextView style="@style/AdminLabel" android:text="Estado de salud" />
            <EditText
                android:id="@+id/etEstadoSalud"
                style="@style/AdminField"
                android:hint="Ej: Excelente"
                android:inputType="text|textCapSentences" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swVacunas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Vacunas al día"
                android:textColor="@color/md_on_surface"
                android:textSize="15sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swEsterilizado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Esterilizado"
                android:textColor="@color/md_on_surface"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:text="Publicar mascota"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/md_on_secondary_container"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/md_secondary_container"
                app:elevation="0dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:indeterminateTint="@color/md_secondary_container"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
