<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_coral_light">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_alert"
                    app:tint="@color/sos_coral"
                    android:contentDescription="SOS" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reporte SOS"
                    android:textColor="@color/md_on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ayúdanos a localizar a una mascota"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tipo de emergencia -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tipo de emergencia"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleLine="true"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipExtraviado"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Extraviado"
                android:checked="true"
                android:textColor="@color/chip_text_design"
                app:chipBackgroundColor="@color/chip_bg_design"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHerido"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Herido"
                android:textColor="@color/chip_text_design"
                app:chipBackgroundColor="@color/chip_bg_design"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipOtro"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Otro"
                android:textColor="@color/chip_text_design"
                app:chipBackgroundColor="@color/chip_bg_design"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Ubicación -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Ubicación"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_location_on"
                android:contentDescription="Ubicación" />

            <EditText
                android:id="@+id/etReferencia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:hint="Calle o punto de referencia"
                android:textColor="@color/md_on_surface"
                android:textColorHint="@color/md_on_surface_variant"
                android:inputType="text|textCapSentences"
                android:maxLines="1" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvUbicacionEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Se usará tu ubicación actual."
            android:textColor="@color/md_on_surface_variant"
            android:textSize="12sp" />

        <!-- Descripción -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Descripción"
            android:textColor="@color/md_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Describe brevemente la situación..."
            android:textColor="@color/md_on_surface"
            android:textColorHint="@color/md_on_surface_variant"
            android:minLines="3"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:background="@drawable/bg_input_rounded"
            android:padding="14dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
