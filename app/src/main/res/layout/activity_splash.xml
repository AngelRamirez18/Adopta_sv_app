<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4EBD0">

    <!-- Círculo decorativo superior derecho -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="-120dp"
        android:layout_marginEnd="-80dp"
        android:background="@drawable/circle_bg"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Círculo decorativo inferior izquierdo -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginBottom="-80dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/circle_bg"
        android:alpha="0.10"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Patitas — recorrido diagonal de arriba izquierda a centro -->
    <ImageView android:id="@+id/paw1"
        android:layout_width="38dp" android:layout_height="38dp"
        android:src="@drawable/ic_paw"
        android:alpha="0"
        android:rotation="20"
        app:tint="#8B5E3C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="140dp"
        android:layout_marginStart="80dp"/>

    <ImageView android:id="@+id/paw2"
        android:layout_width="38dp" android:layout_height="38dp"
        android:src="@drawable/ic_paw"
        android:alpha="0"
        android:rotation="340"
        app:tint="#8B5E3C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="195dp"
        android:layout_marginStart="145dp"/>

    <ImageView android:id="@+id/paw3"
        android:layout_width="38dp" android:layout_height="38dp"
        android:src="@drawable/ic_paw"
        android:alpha="0"
        android:rotation="20"
        app:tint="#8B5E3C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="255dp"
        android:layout_marginStart="100dp"/>

    <ImageView android:id="@+id/paw4"
        android:layout_width="32dp" android:layout_height="32dp"
        android:src="@drawable/ic_paw"
        android:alpha="0"
        android:rotation="340"
        app:tint="#C49A6C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="310dp"
        android:layout_marginStart="160dp"/>

    <ImageView android:id="@+id/paw5"
        android:layout_width="26dp" android:layout_height="26dp"
        android:src="@drawable/ic_paw"
        android:alpha="0"
        android:rotation="20"
        app:tint="#D4B896"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="358dp"
        android:layout_marginStart="120dp"/>

    <ImageView android:id="@+id/paw6"
        android:layout_width="20dp" android:layout_height="20dp"
        android:src="@drawable/ic_paw"
        android:alpha="0"
        android:rotation="340"
        app:tint="#E8D5BC"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="395dp"
        android:layout_marginStart="175dp"/>

    <!-- Logo + título centrados -->

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0"
        android:fontFamily="sans-serif-medium"
        android:text="AdoptaSV"
        android:textColor="#8B5E3C"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="358dp" />

    <!-- Texto "Cargando" con puntos animados -->
    <TextView
        android:id="@+id/tvCargando"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cargando"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#8B5E3C"
        android:alpha="0"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preparando la diversión para tu peludo amigo"
        android:textSize="13sp"
        android:textColor="#B8906A"
        android:textStyle="italic"
        android:gravity="center"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>