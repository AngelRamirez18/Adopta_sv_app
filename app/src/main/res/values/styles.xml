<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Headline" parent="TextAppearance.AppCompat">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Body" parent="TextAppearance.AppCompat">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Label" parent="TextAppearance.AppCompat">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Formularios del área administrativa -->
    <style name="AdminLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:textColor">@color/md_on_surface</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AdminField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_input_rounded</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/md_on_surface</item>
        <item name="android:textColorHint">@color/md_on_surface_variant</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="AdminSpinner">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_input_rounded</item>
        <item name="android:padding">10dp</item>
        <item name="android:minHeight">50dp</item>
    </style>
</resources>